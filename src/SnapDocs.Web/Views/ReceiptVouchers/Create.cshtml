@model SnapDocs.Web.Models.ReceiptVoucherCreateViewModel
@{ ViewData["Title"] = "سند قبض جديد"; }
<div class="page-head"><div><h1>سند قبض جديد</h1><p>مستند مستقل لتسجيل المقبوضات.</p></div><a class="btn secondary" asp-action="Index">رجوع</a></div>
<form asp-action="Create" method="post" class="document-builder"><div class="form-card"><div class="form-grid"><label>الطرف<select asp-for="CustomerId" asp-items="ViewBag.Customers"><option value="">بدون طرف</option></select></label><label>التاريخ<input asp-for="VoucherDate" type="date" /></label><label>المبلغ<input asp-for="Amount" type="number" step="0.01" /></label><label>الخزنة / الحساب<select asp-for="CashAccountId" asp-items="ViewBag.CashAccounts"><option value="">الحساب الافتراضي</option></select></label><label>طريقة الدفع<input asp-for="PaymentMethod" /></label><label>رقم المرجع<input asp-for="ReferenceNumber" /></label></div><label class="mt">ملاحظات<textarea asp-for="Notes" rows="4"></textarea></label><div class="form-actions"><button class="btn primary" type="submit">حفظ سند قبض</button><a class="btn secondary" asp-action="Index">إلغاء</a></div></div><aside class="print-preview sticky-summary"><h3>سند قبض</h3><p>نموذج مستقل مبسط للمقبوضات/المصروفات، بدون جدول أصناف.</p><div class="qrbox">QR VERIFY</div></aside></form>
