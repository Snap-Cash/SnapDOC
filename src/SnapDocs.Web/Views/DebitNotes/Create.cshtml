@model SnapDocs.Web.Models.DebitNoteCreateViewModel
@{ ViewData["Title"] = "إشعار مدين جديد"; }
<div class="page-head"><div><h1>إشعار مدين جديد</h1><p>Debit Note لزيادة رصيد العميل أو تسجيل مصروفات/تسويات إضافية.</p></div><a class="btn secondary" asp-action="Index">رجوع</a></div>
<form asp-action="Create" method="post" class="studio-layout">
    <section class="form-card studio-main">
        <div asp-validation-summary="ModelOnly" class="validation-summary"></div>
        <div class="form-grid">
            <label>العميل<select asp-for="CustomerId" asp-items="ViewBag.Customers"><option value="">بدون عميل</option></select></label>
            <label>التاريخ<input asp-for="DocumentDate" type="date" /></label>
            <label>القيمة<input asp-for="Amount" type="number" step="0.01" /></label>
            <label>رقم المرجع<input asp-for="ReferenceNumber" placeholder="تسوية/رسوم/خدمة إضافية" /></label>
            <label class="span-2">السبب<input asp-for="Reason" /></label>
        </div>
        <label class="mt">ملاحظات<textarea asp-for="Notes" rows="4"></textarea></label>
        <div class="form-actions"><button class="btn primary" type="submit">حفظ الإشعار المدين</button><a class="btn secondary" asp-action="Index">إلغاء</a></div>
    </section>
    <aside class="card studio-side"><h3>تأثير المستند</h3><p class="muted">الإشعار المدين يظهر في كشف حساب العميل كحركة مدين ويزيد الرصيد المستحق.</p><div class="summary-line"><span>نوع الحركة</span><strong>مدين</strong></div></aside>
</form>
