@model SnapDocs.Web.Models.ProductStudioViewModel
@{
    ViewData["Title"] = Model.Name;
}

<div class="page-head">
    <div>
        <p class="snap-eyebrow">Product Studio</p>
        <h1>@Model.Name</h1>
        <p>@Model.Code · @Model.Category · @(Model.IsService ? "خدمة" : "منتج مخزني")</p>
    </div>
    <div class="mini-actions wrap">
        <a class="btn secondary" asp-action="Index">رجوع</a>
        <a class="btn primary" asp-action="Edit" asp-route-id="@Model.Id">تعديل</a>
    </div>
</div>

@if (TempData["Success"] is not null)
{
    <div class="alert-success">@TempData["Success"]</div>
}

<div class="kpi-grid">
    <div class="kpi-card"><span>سعر البيع</span><strong>@Model.SalePrice.ToString("N2")</strong><small>@Model.UnitName</small></div>
    <div class="kpi-card"><span>التكلفة</span><strong>@Model.CostPrice.ToString("N2")</strong><small>هامش @Model.GrossMarginPercent.ToString("N2")%</small></div>
    <div class="kpi-card"><span>الضريبة</span><strong>@Model.TaxRate.ToString("N2")%</strong><small>القيمة الافتراضية للفواتير</small></div>
    <div class="kpi-card"><span>المخزون</span><strong>@(Model.IsService ? "-" : Model.OpeningQuantity.ToString("N3"))</strong><small>@(Model.NeedsReorder ? "يحتاج إعادة طلب" : "مستقر")</small></div>
</div>

<div class="studio-grid mt">
    <div class="table-card">
        <h3>بيانات البند</h3>
        <table class="data-table responsive-table">
            <tbody>
                <tr><td>الكود</td><td><strong>@Model.Code</strong></td></tr>
                <tr><td>الاسم</td><td>@Model.Name</td></tr>
                <tr><td>التصنيف</td><td>@Model.Category</td></tr>
                <tr><td>الوحدة</td><td>@Model.UnitName</td></tr>
                <tr><td>النوع</td><td>@(Model.IsService ? "خدمة" : "منتج مخزني")</td></tr>
                <tr><td>الحالة</td><td><span class="badge @(Model.IsActive ? "success" : "danger")">@(Model.IsActive ? "نشط" : "موقوف")</span></td></tr>
            </tbody>
        </table>
        @if (!string.IsNullOrWhiteSpace(Model.Description))
        {
            <div class="mt"><h4>الوصف</h4><p>@Model.Description</p></div>
        }
    </div>

    <div class="table-card">
        <h3>Timeline</h3>
        <div class="snap-timeline">
        @foreach (var item in Model.Timeline)
        {
            <div class="snap-timeline-item">
                <div class="snap-dot @item.Tone"></div>
                <div><strong>@item.Title</strong><p class="snap-subtitle">@item.Description</p><small>@item.Date.ToString("yyyy/MM/dd")</small></div>
            </div>
        }
        </div>
    </div>
</div>

<div class="table-card mt">
    <h3>ربط سريع بالمستندات</h3>
    <div class="mini-actions wrap">
        <a class="btn small primary" asp-controller="Invoices" asp-action="Create">فاتورة جديدة</a>
        <a class="btn small secondary" asp-controller="Quotations" asp-action="Create">عرض سعر</a>
        <a class="btn small secondary" asp-controller="DeliveryNotes" asp-action="Create">إذن تسليم</a>
    </div>
</div>
