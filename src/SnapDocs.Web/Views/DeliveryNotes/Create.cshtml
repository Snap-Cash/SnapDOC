@model SnapDocs.Web.Models.DeliveryNoteCreateViewModel
@{ ViewData["Title"] = "إذن تسليم جديد"; }
<div class="page-head"><div><h1>إذن تسليم جديد</h1><p>مستند مستقل للتسليم بدون أسعار.</p></div><a class="btn secondary" asp-action="Index">رجوع</a></div>
<form asp-action="Create" method="post" class="document-builder"><div class="form-card"><div class="form-grid"><label>العميل<select asp-for="CustomerId" asp-items="ViewBag.Customers"><option value="">بدون عميل</option></select></label><label>تاريخ التسليم<input asp-for="DeliveryDate" type="date" /></label><label>عنوان التسليم<input asp-for="DeliveryAddress" /></label><label>اسم المستلم<input asp-for="ReceiverName" /></label></div><div class="section-title"><h2>بنود التسليم</h2><button type="button" class="btn secondary" onclick="addDeliveryItem()">+ بند</button></div><table class="items-table" id="deliveryTable"><thead><tr><th>البيان</th><th>الكمية</th><th></th></tr></thead><tbody><tr><td><input name="Items[0].Description" value="منتج / خدمة" /></td><td><input name="Items[0].Quantity" type="number" step="0.01" value="1" /></td><td><button type="button" class="btn small danger" onclick="removeRow(this)">حذف</button></td></tr></tbody></table><label class="mt">ملاحظات<textarea asp-for="Notes" rows="4"></textarea></label><div class="form-actions"><button class="btn primary" type="submit">حفظ إذن التسليم</button><a class="btn secondary" asp-action="Index">إلغاء</a></div></div></form>
@section Scripts {<script>let di=1;function addDeliveryItem(){const tb=document.querySelector('#deliveryTable tbody');const tr=document.createElement('tr');tr.innerHTML=`<td><input name="Items[${di}].Description" /></td><td><input name="Items[${di}].Quantity" type="number" step="0.01" value="1" /></td><td><button type="button" class="btn small danger" onclick="removeRow(this)">حذف</button></td>`;tb.appendChild(tr);di++;}function removeRow(b){b.closest('tr').remove();}</script>}
