@model SnapDocs.Web.Models.Reports.ReportsIndexViewModel
@{
    Layout = null;
    var printedAt = DateTime.Now;
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <title>تقرير SnapDocs</title>
    <link rel="stylesheet" href="~/css/print-engine.css" asp-append-version="true" />
    <style>
        body{font-family:Tahoma,Arial,sans-serif;background:#fff;color:#111827;margin:0;padding:24px}.report-page{max-width:1120px;margin:auto}.report-header{display:flex;justify-content:space-between;align-items:flex-start;border-bottom:2px solid #111827;padding-bottom:16px;margin-bottom:18px}.brand{display:flex;gap:12px;align-items:center}.logo{width:48px;height:48px;border-radius:14px;background:#2563eb;color:white;display:grid;place-items:center;font-weight:800}.muted{color:#6b7280}.report-title{text-align:left}.cards{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin:16px 0}.card{border:1px solid #e5e7eb;border-radius:12px;padding:12px;background:#f9fafb}.card span{display:block;color:#6b7280;font-size:12px}.card strong{font-size:20px}table{width:100%;border-collapse:collapse;margin-top:14px}th{background:#111827;color:#fff;padding:8px;font-size:13px}td{border:1px solid #e5e7eb;padding:8px;font-size:12px}.section{margin-top:22px}.section h3{margin:0 0 8px}.footer{margin-top:26px;border-top:1px solid #e5e7eb;padding-top:10px;display:flex;justify-content:space-between;color:#6b7280;font-size:12px}@@media print{body{padding:0}.no-print{display:none}.report-page{max-width:100%}}
    </style>
</head>
<body onload="setTimeout(() => window.print(), 300)">
<div class="report-page">
    <div class="report-header">
        <div class="brand">
            <div class="logo">S</div>
            <div>
                <h2>SnapDocs</h2>
                <div class="muted">Reports Center</div>
            </div>
        </div>
        <div class="report-title">
            <h1>تقرير الأعمال</h1>
            <div class="muted">من @Model.FromDate.ToString("yyyy/MM/dd") إلى @Model.ToDate.ToString("yyyy/MM/dd")</div>
            <div class="muted">تاريخ الطباعة: @printedAt.ToString("yyyy/MM/dd HH:mm")</div>
        </div>
    </div>

    <div class="cards">
        <div class="card"><span>إجمالي المبيعات</span><strong>@Model.TotalSales.ToString("N2")</strong></div>
        <div class="card"><span>التحصيلات</span><strong>@Model.TotalCollections.ToString("N2")</strong></div>
        <div class="card"><span>الرصيد المستحق</span><strong>@Model.OutstandingBalance.ToString("N2")</strong></div>
        <div class="card"><span>معدل التحصيل</span><strong>@Model.CollectionRate.ToString("N1")%</strong></div>
    </div>

    <div class="section">
        <h3>أعمار الديون</h3>
        <table>
            <thead><tr><th>حالي</th><th>1 - 30</th><th>31 - 60</th><th>61 - 90</th><th>أكثر من 90</th><th>الإجمالي</th></tr></thead>
            <tbody><tr><td>@Model.Aging.Current.ToString("N2")</td><td>@Model.Aging.Days1To30.ToString("N2")</td><td>@Model.Aging.Days31To60.ToString("N2")</td><td>@Model.Aging.Days61To90.ToString("N2")</td><td>@Model.Aging.Over90.ToString("N2")</td><td><strong>@Model.Aging.Total.ToString("N2")</strong></td></tr></tbody>
        </table>
    </div>

    <div class="section">
        <h3>أفضل العملاء حسب المبيعات</h3>
        <table>
            <thead><tr><th>الكود</th><th>العميل</th><th>المبيعات</th><th>التحصيلات</th><th>الرصيد</th></tr></thead>
            <tbody>
            @foreach (var row in Model.TopCustomersBySales)
            {
                <tr><td>@row.CustomerCode</td><td>@row.CustomerName</td><td>@row.Sales.ToString("N2")</td><td>@row.Collections.ToString("N2")</td><td>@row.Balance.ToString("N2")</td></tr>
            }
            </tbody>
        </table>
    </div>

    <div class="section">
        <h3>آخر المستندات</h3>
        <table>
            <thead><tr><th>المستند</th><th>العميل</th><th>النوع</th><th>التاريخ</th><th>الإجمالي</th><th>المتبقي</th></tr></thead>
            <tbody>
            @foreach (var doc in Model.RecentDocuments)
            {
                <tr><td>@doc.Number</td><td>@doc.CustomerName</td><td>@doc.Type</td><td>@doc.DocumentDate.ToString("yyyy/MM/dd")</td><td>@doc.Total.ToString("N2")</td><td>@doc.Remaining.ToString("N2")</td></tr>
            }
            </tbody>
        </table>
    </div>

    <div class="footer">
        <span>Generated by SnapDocs</span>
        <span>توقيع المدير المالي: __________________</span>
    </div>
</div>
</body>
</html>
