@model SnapDocs.Domain.Entities.Document
@using SnapDocs.Domain.Enums
@{
    ViewData["Title"] = "Quotation Studio " + Model.Number;
    var isExpired = Model.DueDate.HasValue && Model.DueDate.Value.Date < DateTime.Today && Model.Status != DocumentStatus.Paid;
}

<div class="quote-details-hero no-print">
    <div>
        <span class="eyebrow">Quotation Studio Pro</span>
        <h1>عرض السعر @Model.Number</h1>
        <p>@(Model.Customer?.Name ?? "بدون عميل") · @Model.DocumentDate.ToString("yyyy/MM/dd") · Verify @Model.VerifyCode</p>
    </div>
    <div class="quote-details-actions">
        <partial name="_DocumentWorkflowActions" model="Model" />
        <form asp-action="ConvertToInvoice" asp-route-id="@Model.Id" method="post" class="inline-form">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn primary">تحويل لفاتورة</button>
        </form>
        <a class="btn secondary" asp-action="Duplicate" asp-route-id="@Model.Id">تكرار</a>
        <a class="btn secondary" asp-controller="Print" asp-action="Document" asp-route-id="@Model.Id">طباعة</a>
        <a class="btn secondary" asp-action="Index">رجوع</a>
    </div>
</div>

@if (TempData["Success"] is not null) { <div class="alert-success no-print">@TempData["Success"]</div> }
@if (isExpired) { <div class="alert-warning no-print">انتهت صلاحية عرض السعر. يمكنك تكراره بتاريخ صلاحية جديد أو تحويله لفاتورة عند موافقة العميل.</div> }

<div class="quote-studio-view">
    <main class="quote-studio-view-main">
        <section class="quote-document-sheet">
            <div class="quote-watermark">@Model.Status</div>
            <header class="quote-print-header">
                <div>
                    <h2>SnapDocs Demo Company</h2>
                    <p>Cairo, Egypt · info@snapdocs.local</p>
                </div>
                <div class="quote-print-meta">
                    <strong>عرض سعر</strong>
                    <span>@Model.Number</span>
                    <span>@Model.DocumentDate.ToString("yyyy/MM/dd")</span>
                    <partial name="_DocumentStatusBadge" model="Model.Status" />
                </div>
            </header>

            <div class="quote-party-grid">
                <div class="quote-party-box">
                    <span>العميل</span>
                    <strong>@(Model.Customer?.Name ?? "بدون عميل")</strong>
                    <p>@Model.Customer?.Phone</p>
                </div>
                <div class="quote-party-box">
                    <span>الصلاحية</span>
                    <strong>@(Model.DueDate?.ToString("yyyy/MM/dd") ?? "غير محدد")</strong>
                    <p>@(isExpired ? "منتهي الصلاحية" : "ساري")</p>
                </div>
                <div class="quote-party-box">
                    <span>كود التحقق</span>
                    <strong>@Model.VerifyCode</strong>
                    <p>/verify/@Model.VerifyCode</p>
                </div>
            </div>

            <table class="quote-print-table">
                <thead><tr><th>#</th><th>البيان</th><th>الكمية</th><th>السعر</th><th>خصم</th><th>الإجمالي</th></tr></thead>
                <tbody>
                @{ var i = 1; }
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td>@i</td>
                        <td>@item.Description</td>
                        <td>@item.Quantity.ToString("N3")</td>
                        <td>@item.UnitPrice.ToString("N2")</td>
                        <td>@item.Discount.ToString("N2")</td>
                        <td>@item.LineTotal.ToString("N2")</td>
                    </tr>
                    i++;
                }
                </tbody>
            </table>

            <div class="quote-print-bottom">
                <div class="quote-terms">
                    <h3>الشروط والملاحظات</h3>
                    <p>@(string.IsNullOrWhiteSpace(Model.Notes) ? "لا توجد شروط إضافية." : Model.Notes)</p>
                </div>
                <div class="quote-totals-box">
                    <div><span>الإجمالي</span><strong>@Model.SubTotal.ToString("N2")</strong></div>
                    <div><span>الخصم</span><strong>@Model.Discount.ToString("N2")</strong></div>
                    <div><span>الضريبة</span><strong>@Model.Tax.ToString("N2")</strong></div>
                    <div class="grand"><span>إجمالي العرض</span><strong>@Model.Total.ToString("N2")</strong></div>
                </div>
            </div>

            <footer class="quote-signatures">
                <span>مسؤول المبيعات</span>
                <span>توقيع العميل</span>
            </footer>
        </section>
    </main>

    <aside class="quote-studio-view-side no-print">
        <div class="quote-side-card">
            <h3>ملخص العرض</h3>
            <div class="quote-total-row"><span>الحالة</span><strong>@Model.Status</strong></div>
            <div class="quote-total-row"><span>الصلاحية</span><strong>@(isExpired ? "منتهي" : "ساري")</strong></div>
            <div class="quote-total-row grand"><span>القيمة</span><strong>@Model.Total.ToString("N2")</strong></div>
        </div>
        <div class="quote-side-card">
            <h3>Workflow</h3>
            <div class="quote-mini-timeline">
                <div class="done"><span></span><b>Created</b><small>@Model.CreatedAtUtc.ToLocalTime().ToString("yyyy/MM/dd HH:mm")</small></div>
                <div class="@(Model.Status == DocumentStatus.Sent || Model.Status == DocumentStatus.Paid ? "done" : "")"><span></span><b>Sent</b><small>مشاركة أو تغيير حالة</small></div>
                <div class="@(Model.Status == DocumentStatus.Paid ? "done" : "")"><span></span><b>Accepted</b><small>تحويل إلى فاتورة</small></div>
            </div>
        </div>
        <div class="quote-side-card">
            <h3>مشاركة</h3>
            <div class="quote-actions-stack">
                <a class="btn primary" href="https://wa.me/?text=@Uri.EscapeDataString($"عرض سعر رقم {Model.Number} بقيمة {Model.Total:N2} - تحقق: {Model.VerifyCode}")" target="_blank">إرسال واتساب</a>
                <a class="btn secondary" asp-controller="Print" asp-action="Verify" asp-route-code="@Model.VerifyCode">صفحة التحقق</a>
            </div>
        </div>
    </aside>
</div>
